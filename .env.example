# Local development (npm run dev)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000

# Production build (npm run build) uses Render API by default when these are unset:
# VITE_API_BASE_URL=https://amma-ka-khana-api.onrender.com/api/v1
# VITE_SOCKET_URL=https://amma-ka-khana-api.onrender.com

# Default admin credentials (must match API ADMIN_EMAIL / ADMIN_PASSWORD)
# Email: admin@ammakakhana.com  Password: Admin@123
